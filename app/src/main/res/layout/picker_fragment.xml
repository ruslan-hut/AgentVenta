<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="ua.com.programmer.agentventa.presentation.features.picker.PickerViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/item_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSecondaryContainer"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:text="@string/holder_text"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingTop="16dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/item_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSecondaryContainer"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@+id/item_description" />

        <!-- Row 1: [quantity] unit [price] $ -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/item_quantity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/attr_quantity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/item_unit"
            app:layout_constraintTop_toBottomOf="@+id/item_code"
            app:layout_constraintHorizontal_weight="1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_quantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/item_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/holder_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:gravity="center"
            android:minWidth="32dp"
            app:layout_constraintStart_toEndOf="@+id/item_quantity"
            app:layout_constraintEnd_toStartOf="@+id/item_price"
            app:layout_constraintBottom_toBottomOf="@+id/item_quantity"
            app:layout_constraintTop_toTopOf="@+id/item_quantity" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/item_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/attr_price"
            app:layout_constraintStart_toEndOf="@+id/item_unit"
            app:layout_constraintEnd_toStartOf="@+id/price_unit"
            app:layout_constraintTop_toTopOf="@+id/item_quantity"
            app:layout_constraintHorizontal_weight="1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"
                android:enabled="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/price_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/holder_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/item_price"
            app:layout_constraintTop_toTopOf="@+id/item_price" />

        <!-- Available quantity info (left-aligned, under quantity+price row) -->

        <LinearLayout
            android:id="@+id/available_quantity_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/item_quantity">

            <TextView
                android:id="@+id/available_quantity_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="@string/available_quantity" />

            <TextView
                android:id="@+id/available_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingRight="4dp"
                android:paddingLeft="4dp"
                android:text="@string/holder_number_decimal"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/rest_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="@string/holder_text" />
            <TextView
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/package_info_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="@string/attr_per_package"/>
            <TextView
                android:id="@+id/package_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:text="@string/holder_number" />
        </LinearLayout>

        <!-- Row 2: [discount %] (spacer) [price with discount] $ -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/item_discount_percent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/attr_discount_percent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/item_unit"
            app:layout_constraintTop_toBottomOf="@+id/available_quantity_view">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_discount_percent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/item_discount_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_marginTop="4dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="@string/attr_price_with_discount"
            app:layout_constraintStart_toEndOf="@+id/item_unit"
            app:layout_constraintEnd_toStartOf="@+id/discount_price_unit"
            app:layout_constraintTop_toBottomOf="@+id/available_quantity_view">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_discount_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/discount_price_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/holder_text"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/item_discount_price"
            app:layout_constraintTop_toTopOf="@+id/item_discount_price" />

        <!-- Row 3: total (right-aligned) -->

        <LinearLayout
            android:id="@+id/discount_total_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/item_discount_percent">

            <TextView
                android:id="@+id/total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/attr_total" />

            <TextView
                android:id="@+id/total_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Checkboxes -->

        <LinearLayout
            android:id="@+id/item_is_packed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/discount_total_row">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/flag_package"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/box_is_packed" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_is_demand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:minHeight="48dp"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/item_is_packed">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/demand"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/box_is_demand" />
        </LinearLayout>

        <!-- Price list -->

        <LinearLayout
            android:id="@+id/block_price_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/item_is_demand" >

            <LinearLayout
                android:id="@+id/price_list_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:text="@string/price_variants" />

                <TextView
                    android:layout_width="4dp"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/price_list_title_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/price_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="32dp">

            </androidx.recyclerview.widget.RecyclerView>

            <LinearLayout
                android:id="@+id/base_price_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:text="@string/attr_base_price" />

                <TextView
                    android:id="@+id/base_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingRight="4dp"
                    android:paddingLeft="4dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textStyle="bold"
                    android:text="@string/holder_number_decimal" />
            </LinearLayout>

        </LinearLayout>

        <!-- Competitor prices -->

        <LinearLayout
            android:id="@+id/block_competitor_price_list"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/block_price_list">

            <TextView
                android:id="@+id/competitor_price_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/competitor_price_list_title"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/competitor_price_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="32dp">

            </androidx.recyclerview.widget.RecyclerView>

        </LinearLayout>

        <!-- Buttons -->

        <LinearLayout
            android:id="@+id/buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/block_competitor_price_list">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_yes"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
