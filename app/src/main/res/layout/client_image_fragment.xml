<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="image"
            type="ua.com.programmer.agentventa.data.local.entity.ClientImage" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:id="@+id/image_container">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/item_image"
            android:scaleType="centerInside"
            android:contentDescription="@{image.description}" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/is_default"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="2dp"
                    android:contentDescription="@string/cd_default_image"
                    android:src="@drawable/baseline_check_box_24" />

                <ImageView
                    android:id="@+id/is_sent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="2dp"
                    android:contentDescription="@string/cd_sent_status"
                    android:src="@drawable/baseline_cloud_upload_24" />
            </LinearLayout>

            <TextView
                android:id="@+id/item_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textColor="?attr/colorOnPrimary"
                android:shadowColor="@color/md_theme_scrim"
                android:shadowRadius="4"
                android:shadowDx="1"
                android:shadowDy="1"
                android:text="@{image.description}"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

        </LinearLayout>

    </FrameLayout>
</layout>